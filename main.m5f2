me=\"MODE\">palette</field><field name=\"COLOR\">#ff0000</field></block></value><value name=\"BGCOLOR\"><block type=\"color_rgb_palette\" id=\"n9~]2U{fIU=^7iCH48!y\"><mutation mode=\"palette\"></mutation><field name=\"MODE\">palette</field><field name=\"COLOR\">#ff0000</field></block></value><next><block type=\"math_change\" id=\"*X6T-[z$:QkL*^a/[u4q\"><field name=\"VAR\" id=\"n0b:3z2h1YTeB2P9]l$+\">counter</field><value name=\"DELTA\"><shadow type=\"math_number\" id=\"Ew|RRMxXldv9s9dn%/zO\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">1</field></shadow></value><next><block type=\"label_set_text\" id=\"[x#})37K?SxFUFt5Jo5.\"><field name=\"NAME\">counternumber</field><value name=\"TEXT\"><shadow type=\"text\" id=\"(JhBD1S!l^[*e;ZBNhr.\"><field name=\"TEXT\">Label</field></shadow><block type=\"text_convert_str\" id=\"9OPaL[t`GJJXZtr8HB)1\"><value name=\"VALUE\"><block type=\"variables_get\" id=\"NpC.BGHu+2gUkvw#7WV%\"><field name=\"VAR\" id=\"n0b:3z2h1YTeB2P9]l$+\">counter</field></block></value></block></value><next><block type=\"time_sleep_millisecond\" id=\"`bhlxbB0{{CXY7Y6^5BV\"><value name=\"MS\"><shadow type=\"math_number\" id=\"Pyn|C,miRb7L+J,Vm;-C\"><mutation max=\"Infinity\" min=\"0\" precision=\"0\"></mutation><field name=\"NUM\">3000</field></shadow></value><next><block type=\"circle_set_color_multiple\" id=\"5,|@q}STFmIy36Ss?lSs\"><field name=\"NAME\">circle0</field><value name=\"COLOR\"><block type=\"color_rgb_palette\" id=\";W_EGqw9fi:M-JR=|]q3\"><mutation mode=\"palette\"></mutation><field name=\"MODE\">palette</field><field name=\"COLOR\">#009900</field></block></value><value name=\"BGCOLOR\"><block type=\"color_rgb_palette\" id=\"O$Smtuk?s1ezX2;#Sqi)\"><mutation mode=\"palette\"></mutation><field name=\"MODE\">palette</field><field name=\"COLOR\">#009900</field></block></value></block></next></block></next></block></next></block></next></block></statement></block></next></block></next></block></next></block></next></block></statement></block>","screen":[{"simulationName":"Built-in","type":"builtin","width":128,"height":128,"scale":1.5,"screenName":"","blockId":"","screenColorType":0,"id":"builtin","createTime":1780758211845}],"logicWhenNum":0,"pythonCode":"import os, sys, io\nimport M5\nfrom M5 import *\nimport asyncio\nimport time\n\n\n\naccData = None\ncounterLabel = None\nunit = None\ntitle1 = None\ncircle0 = None\ncounternumber = None\n\n\nimport math\n\ncounter = None\naccelX = None\naccelY = None\naccelZ = None\n\n\ndef btnA_wasClicked_event(state):\n  global accData, counterLabel, unit, title1, circle0, counternumber, counter, accelX, accelY, accelZ\n  counter = 0\n  counternumber.setText(str(counter))\n\n\nasync def main():\n  global accData, counterLabel, unit, title1, circle0, counternumber, counter, accelX, accelY, accelZ\n\n  M5.begin()\n  Widgets.fillScreen(0x000000)\n  accData = Widgets.Label(\"---\", 8, 41, 1.0, 0xffffff, 0x222222, Widgets.FONTS.DejaVu18)\n  counterLabel = Widgets.Label(\"Total:\", 6, 92, 1.0, 0xffffff, 0x222222, Widgets.FONTS.DejaVu18)\n  unit = Widgets.Label(\"g\", 47, 44, 1.0, 0xffffff, 0x222222, Widgets.FONTS.DejaVu18)\n  title1 = Widgets.Title(\"BumpLess\", 15, 0x000000, 0x43e8e5, Widgets.FONTS.DejaVu18)\n  circle0 = Widgets.Circle(99, 52, 24, 0xffffff, 0xf0b130)\n  counternumber = Widgets.Label(\"0\", 74, 91, 1.0, 0xffffff, 0x222222, Widgets.FONTS.DejaVu18)\n\n  BtnA.setCallback(type=BtnA.CB_TYPE.WAS_CLICKED, cb=btnA_wasClicked_event)\n\n  counter = 0\n  time.sleep_ms(2000)\n  circle0.setColor(color=0x009900, fill_c=0x009900)\n\n\n  while True:\n    await asyncio.sleep_ms(10)\n    M5.update()\n    (accelX, accelY, accelZ) = Imu.getAccel()\n    accData.setText(str(round(math.sqrt(accelX * accelX + accelY * accelY + accelZ * accelZ), 1)))\n    time.sleep_ms(1)\n    if 1.4 < (round(math.sqrt(accelX * accelX) + math.sqrt(accelY * accelY) + math.sqrt(accelZ * accelZ), 2)):\n      circle0.setColor(color=0xff0000, fill_c=0xff0000)\n      counter = (counter if isinstance(counter, (int, float)) else 0) + 1\n      counternumber.setText(str(str(counter)))\n      time.sleep_ms(3000)\n      circle0.setColor(color=0x009900, fill_c=0x009900)\n  \n\nif __name__ == '__main__':\n  try:\n    asyncio.run(main())\n  except (asyncio.CancelledError, KeyboardInterrupt) as e:\n    from utility import print_error_msg\n    print_error_msg(e)\n  except ImportError:\n    print(\"please update to latest firmware\")\n  finally:\n    pass","customList":[]}