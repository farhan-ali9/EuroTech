bump-less.club {
	# Caddy automatically obtains & renews a Let's Encrypt certificate for this
	# domain (HTTP-01 challenge on :80) and redirects HTTP → HTTPS.
	encode gzip
	root * /srv

	# API → backend container
	@api path /report /report/* /hazards /hazards/* /health
	handle @api {
		reverse_proxy backend:8000
	}

	# Content-hashed build assets (/assets/index-<hash>.js|css) → cache forever.
	@assets path /assets/*
	handle @assets {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# SPA shell + everything else → always revalidate so new deploys reach clients
	# immediately (no stale index.html pointing at an old bundle).
	handle {
		header Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}
