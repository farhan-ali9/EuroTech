# Production env for docker-compose.prod.yml.
# deploy.sh passes VITE_MAPBOX_TOKEN automatically (read from frontend/.env),
# so you normally don't need this file. It's here for reference / manual runs.

VITE_MAPBOX_TOKEN=pk.your_public_token_here

# Optional port overrides (handy for local testing so you don't need 80/443):
# HTTP_PORT=8080
# HTTPS_PORT=8443
